# ============================================================
# 微信公众号助手配置文件
# ============================================================
# 复制此文件为 .env 并填入你的实际配置值
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# 微信公众号配置（必填）
# ------------------------------------------------------------
# 获取方式：登录微信公众平台 → 设置与开发 → 基本配置
# https://mp.weixin.qq.com

# 公众号 AppID
# 必填项，在基本配置页面可以直接看到
WECHAT_APP_ID=your_app_id_here

# 公众号 AppSecret
# 必填项，在基本配置页面可以查看或重置
# 注意：此密钥非常重要，不要泄露给他人
WECHAT_APP_SECRET=your_app_secret_here

# 服务器配置 Token（可选）
# 仅在启用服务器配置时需要，用于消息接口验证
# 如果不使用消息接口功能，可以留空或保持默认
WECHAT_TOKEN=your_token_here

# 消息加解密密钥（可选）
# 仅在启用消息加密时需要，43位字符
# 如果不使用消息加密功能，可以留空或保持默认
WECHAT_AES_KEY=your_aes_key_here

# ------------------------------------------------------------
# 文章排版配置（可选）
# ------------------------------------------------------------

# 默认主题风格
# 可选值：default, modern, minimal, neon, clean, warm
# 默认：default
THEME=default

# 是否在文章末尾添加Ai生成签名
# 可选值：true, false
# 默认：true
FOOTER_SIGNATURE=true

# ------------------------------------------------------------
# 图片生成 API 配置
# ------------------------------------------------------------
# 支持兼容 OpenAI /images/generations 格式的接口
# 如果你使用 OpenAI 官方接口，只需填写 IMAGE_API_KEY
# 如果你使用第三方兼容接口，需要修改 IMAGE_API_BASE_URL 和 IMAGE_MODEL

# API 基础地址
# OpenAI 官方：https://api.openai.com/v1
# 其他兼容接口：填写你的服务地址，如 https://your-api.com/v1
IMAGE_API_BASE_URL=https://api.openai.com/v1

# API 端点路径
# 一般不需要修改，保持默认即可
IMAGE_API_ENDPOINT=/images/generations

# API 密钥
# 必填项，从你的图片生成服务提供商获取
# 注意：此密钥非常重要，不要泄露给他人
IMAGE_API_KEY=your_api_key_here

# 图片生成模型名称
# OpenAI：dall-e-2, dall-e-3, gpt-image-1 等
# 其他服务：填写对应的模型名称
IMAGE_MODEL=gpt-image-1

# 图片尺寸
# 常见尺寸：1024x1024（正方形）、1792x1024（横版）、1024x1792（竖版）
# 公众号封面推荐：1792x1024 或 1024x1024
IMAGE_SIZE=1024x1024

# 图片响应格式（可选）
# 可选值：url（返回图片链接）、b64_json（返回 Base64 编码）
# 留空则使用接口默认值
IMAGE_RESPONSE_FORMAT=

# 附加 API 参数（可选）
# JSON 格式，用于传递额外参数
# 示例：{"quality":"high","style":"vivid"}
IMAGE_API_EXTRA_JSON=
